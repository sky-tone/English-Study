/* sentence-area.wxss - 句子拼装区域样式 */

.sentence-area-container {
  margin: 16rpx 20rpx;
}

.area-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.area-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.area-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.clear-btn {
  background: #f0f0f0;
  color: #666;
}

.submit-btn {
  background: linear-gradient(135deg, #27AE60, #2ECC71);
  color: #fff;
}

/* 拼装区域 */
.assembly-zone {
  min-height: 180rpx;
  background: #fff;
  border: 4rpx dashed #ccc;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.assembly-zone.drop-target {
  border-color: #4A90D9;
  background: rgba(74, 144, 217, 0.05);
  box-shadow: 0 0 20rpx rgba(74, 144, 217, 0.2);
}

/* 空状态 */
.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.empty-icon {
  font-size: 48rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.empty-sub {
  font-size: 22rpx;
  color: #bbb;
  font-style: italic;
}

/* 已拼装积木行 */
.sentence-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
  width: 100%;
}

.placed-block {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  animation: placeIn 0.3s ease-out;
}

@keyframes placeIn {
  from {
    opacity: 0;
    transform: scale(0.8) translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.placed-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 32rpx;
  height: 32rpx;
  background: #E74C3C;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.2);
}

.period {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-left: 4rpx;
}

/* 句子预览 */
.sentence-preview {
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: #F0F8FF;
  border-radius: 12rpx;
  border-left: 6rpx solid #4A90D9;
}

.preview-label {
  font-size: 22rpx;
  color: #666;
  margin-right: 8rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #333;
  font-style: italic;
}

/* 验证反馈 */
.feedback {
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.feedback.success {
  background: #E8F8F0;
  border: 2rpx solid #27AE60;
}

.feedback.warning {
  background: #FFF8E1;
  border: 2rpx solid #F39C12;
}

.feedback.error {
  background: #FDEDEC;
  border: 2rpx solid #E74C3C;
}

.feedback-icon {
  font-size: 32rpx;
}

.feedback-text {
  font-size: 24rpx;
  color: #333;
  flex: 1;
}

/* 已完成句子列表 */
.completed-sentences {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #FAFFFE;
  border-radius: 16rpx;
  border: 2rpx solid #E8F8F0;
}

.completed-header {
  margin-bottom: 12rpx;
}

.completed-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #27AE60;
}

.completed-item {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.completed-item:last-child {
  border-bottom: none;
}

.completed-number {
  font-size: 24rpx;
  color: #27AE60;
  font-weight: bold;
  min-width: 36rpx;
}

.completed-text {
  font-size: 24rpx;
  color: #333;
}

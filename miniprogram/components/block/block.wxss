/* block.wxss - 磁性积木样式 */

.block-container {
  position: absolute;
  display: inline-flex;
  align-items: center;
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
  min-height: 72rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  cursor: grab;
  user-select: none;
}

.block-inner {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.block-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  white-space: nowrap;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 连接点 */
.connector {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.connector-left {
  margin-right: 6rpx;
}

.connector-right {
  margin-left: 6rpx;
}

/* 类型标签 */
.block-tag {
  position: absolute;
  top: -16rpx;
  right: -8rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 12rpx;
  padding: 2rpx 10rpx;
}

.tag-text {
  color: #fff;
  font-size: 18rpx;
}

/* 震动动画 */
.shake {
  animation: blockShake 0.5s ease-in-out;
}

@keyframes blockShake {
  0%, 100% { transform: translateX(0) rotate(0); }
  10% { transform: translateX(-6rpx) rotate(-2deg); }
  20% { transform: translateX(6rpx) rotate(2deg); }
  30% { transform: translateX(-6rpx) rotate(-1deg); }
  40% { transform: translateX(6rpx) rotate(1deg); }
  50% { transform: translateX(-4rpx) rotate(0); }
  60% { transform: translateX(4rpx) rotate(0); }
  70% { transform: translateX(-2rpx) rotate(0); }
  80% { transform: translateX(2rpx) rotate(0); }
  90% { transform: translateX(-1rpx) rotate(0); }
}

/* 弹跳动画 */
.bounce {
  animation: blockBounce 0.4s ease-out;
}

@keyframes blockBounce {
  0% { transform: scale(1); }
  30% { transform: scale(1.15); }
  50% { transform: scale(0.95); }
  70% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

/* 拒绝提示气泡 */
.reject-bubble {
  position: absolute;
  bottom: calc(100% + 16rpx);
  left: 50%;
  transform: translateX(-50%) translateY(10rpx);
  background: rgba(231, 76, 60, 0.95);
  color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
  z-index: 1000;
  max-width: 500rpx;
  white-space: normal;
  text-align: center;
}

.reject-bubble::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 50%;
  margin-left: -10rpx;
  border-width: 10rpx;
  border-style: solid;
  border-color: rgba(231, 76, 60, 0.95) transparent transparent transparent;
}

.reject-bubble.visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.reject-text {
  color: #fff;
  font-size: 22rpx;
  line-height: 1.4;
}

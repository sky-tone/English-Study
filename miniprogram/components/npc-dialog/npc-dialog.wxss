/* npc-dialog.wxss - NPC 对话组件样式 */

.npc-dialog-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.npc-dialog-container.visible {
  opacity: 1;
}

.dialog-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
}

.npc-character {
  position: relative;
  z-index: 201;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 40rpx;
}

/* NPC 头像 */
.npc-avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.npc-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid #fff;
}

.npc-avatar-emoji {
  font-size: 60rpx;
}

.npc-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 对话气泡 */
.dialog-bubble {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  max-width: 600rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
  position: relative;
}

.dialog-bubble::before {
  content: '';
  position: absolute;
  top: -16rpx;
  left: 50%;
  margin-left: -16rpx;
  border-width: 0 16rpx 16rpx 16rpx;
  border-style: solid;
  border-color: transparent transparent #fff transparent;
}

.animate-pop {
  animation: popIn 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes popIn {
  from {
    opacity: 0;
    transform: scale(0.5) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.dialog-message {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.dialog-sub {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 24rpx;
}

.dialog-actions {
  display: flex;
  justify-content: center;
}

.dialog-btn {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
}

.dialog-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

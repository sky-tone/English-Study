/* backpack.wxss - 词汇背包样式 */

.backpack-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  z-index: 100;
}

.backpack-container.expanded {
  max-height: 500rpx;
}

/* 展开/收起按钮 */
.backpack-handle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.handle-icon {
  font-size: 32rpx;
}

.handle-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.handle-arrow {
  font-size: 20rpx;
  color: #999;
}

/* 分类标签栏 */
.category-tabs {
  display: flex;
  padding: 12rpx 20rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-tab {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  font-size: 22rpx;
  color: #666;
}

.category-tab.active {
  background: #4A90D9;
  color: #fff;
}

/* 词汇卡片滚动区域 */
.words-scroll {
  white-space: nowrap;
  padding: 16rpx 20rpx;
}

.words-row {
  display: inline-flex;
  gap: 16rpx;
}

.word-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 16rpx 24rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  min-width: 160rpx;
  border: 2rpx solid #E8ECF0;
  transition: all 0.2s ease;
}

.word-card:active {
  background: #E8F0FE;
  border-color: #4A90D9;
  transform: scale(0.95);
}

.word-english {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.word-chinese {
  font-size: 20rpx;
  color: #666;
}

.word-phonetic {
  font-size: 18rpx;
  color: #999;
  font-style: italic;
}

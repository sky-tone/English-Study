/* radar-chart.wxss - 雷达图样式 */

.radar-container {
  padding: 24rpx;
}

.radar-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.radar-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.radar-subtitle {
  font-size: 22rpx;
  color: #999;
}

/* Canvas 区域 */
.radar-canvas-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.radar-canvas {
  background: #FAFAFA;
  border-radius: 16rpx;
}

/* 维度详情列表 */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dimension-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
}

.dim-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.dim-label {
  font-size: 24rpx;
  color: #333;
  width: 120rpx;
  flex-shrink: 0;
}

.dim-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dim-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
}

.dim-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  width: 72rpx;
  text-align: right;
  flex-shrink: 0;
}

.dim-level {
  font-size: 20rpx;
  color: #999;
  width: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

/* 综合评价 */
.overall-section {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.overall-label {
  font-size: 26rpx;
  color: #666;
}

.overall-score {
  font-size: 36rpx;
  font-weight: bold;
}

.overall-score.excellent {
  color: #27AE60;
}

.overall-score.good {
  color: #4A90D9;
}

.overall-score.average {
  color: #F39C12;
}

.overall-score.weak {
  color: #E74C3C;
}

.overall-desc {
  font-size: 22rpx;
  color: #666;
  flex: 1;
  text-align: right;
}

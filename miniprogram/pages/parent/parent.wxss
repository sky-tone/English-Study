/* parent.wxss - 家长中心样式 */

.parent-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: #F5F7FA;
}

/* 头部 */
.parent-header {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #F39C12, #E67E22);
  gap: 20rpx;
}

.parent-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji {
  font-size: 48rpx;
}

.parent-info {
  flex: 1;
}

.parent-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.parent-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.vip-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 22rpx;
}

.vip-badge.active {
  background: #FFD700;
  color: #333;
  font-weight: bold;
}

/* 绑定区域 */
.bind-section {
  margin-top: -20rpx;
}

.bind-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.bind-title {
  font-size: 28rpx;
  font-weight: bold;
}

.bind-status {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  font-size: 22rpx;
  color: #999;
}

.bind-status.bound {
  background: #E8F8F0;
  color: #27AE60;
}

.bind-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.bind-name, .bind-class, .bind-school {
  font-size: 24rpx;
  color: #666;
}

.bind-action {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
}

/* 统计区域 */
.stats-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90D9;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 错题列表 */
.errors-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.errors-title {
  font-size: 28rpx;
  font-weight: bold;
}

.errors-count {
  font-size: 22rpx;
  color: #999;
}

.error-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.error-item:last-child {
  border-bottom: none;
}

.error-type-badge {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #fff;
  white-space: nowrap;
  flex-shrink: 0;
}

.error-context {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.no-errors {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

/* 导出区域 */
.export-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.export-title {
  font-size: 28rpx;
  font-weight: bold;
}

.vip-tag {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  background: #FFD700;
  font-size: 20rpx;
  font-weight: bold;
  color: #333;
}

.export-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.export-btn {
  display: flex;
  justify-content: center;
}

/* VIP 推广 */
.vip-promo {
  text-align: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFE0B2);
  border-radius: 16rpx;
}

.vip-price {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #F39C12;
  margin-bottom: 8rpx;
}

.vip-features {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.vip-btn {
  display: inline-block;
  background: linear-gradient(135deg, #F39C12, #E67E22) !important;
}

/* 拍照上传区域 */
.upload-section {
  margin-top: 0;
}

.upload-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.upload-title {
  font-size: 28rpx;
  font-weight: bold;
}

.upload-count {
  font-size: 22rpx;
  color: #999;
}

.upload-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #FAFAFA;
}

.photo-add:active {
  background: #F0F0F0;
  border-color: #999;
}

.add-icon {
  font-size: 48rpx;
}

.add-text {
  font-size: 22rpx;
  color: #999;
}

.upload-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.btn-clear {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  font-size: 24rpx;
  color: #999;
}

.btn-clear:active {
  background: #eee;
  color: #666;
}

/* index.wxss - 首页样式 */

.index-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* Hero Section */
.hero-section {
  padding: 0 20rpx;
  margin-bottom: 40rpx;
}

.hero-bg {
  background: linear-gradient(135deg, #4A90D9, #5B6ABF, #9B59B6);
  border-radius: 0 0 40rpx 40rpx;
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin: 0 -20rpx;
}

.hero-emoji {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.hero-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

/* Section Title */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  padding: 0 20rpx;
  display: block;
  margin-bottom: 20rpx;
}

/* Role Cards */
.role-section {
  margin-bottom: 40rpx;
}

.role-card {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 16rpx 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.role-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.role-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.student-icon {
  background: linear-gradient(135deg, #4A90D9, #5B6ABF);
}

.parent-icon {
  background: linear-gradient(135deg, #F39C12, #E67E22);
}

.teacher-icon {
  background: linear-gradient(135deg, #27AE60, #2ECC71);
}

.role-icon {
  font-size: 44rpx;
}

.role-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.role-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.role-name-en {
  font-size: 22rpx;
  color: #999;
}

.role-desc {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.role-arrow {
  font-size: 24rpx;
  color: #ccc;
  margin-left: 12rpx;
}

/* Level Preview */
.preview-section {
  margin-bottom: 40rpx;
}

.level-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.level-cards {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 20rpx;
}

.level-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 280rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  gap: 8rpx;
}

.level-card:active {
  transform: scale(0.97);
}

.level-badge {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.level-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  white-space: normal;
}

.level-subtitle {
  font-size: 20rpx;
  color: #666;
  text-align: center;
  white-space: normal;
}

.level-difficulty {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 24rpx;
}

/* Footer */
.footer {
  text-align: center;
  padding: 40rpx 20rpx;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: #bbb;
}

.footer-sub {
  font-size: 20rpx;
  color: #ddd;
}
